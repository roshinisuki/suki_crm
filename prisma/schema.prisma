  @@index([rfqId])
  @@index([changedAt])
  @@index([changedById])
}

model QuotationStatusHistory {
  id           String    @id @default(uuid())
  quotationId  String
  quotation    Quotation @relation(fields: [quotationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  fromStatus   String?
  toStatus     String
  changedById  String?
  changedBy    User?     @relation("ChangedQuotationStatus", fields: [changedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  notes        String?   @db.NVarChar(Max)
  changedAt    DateTime  @default(now())

  @@index([quotationId])
  @@index([changedAt])
  @@index([changedById])
}

model QuotationRevisionSnapshot {
  id             String    @id @default(uuid())
  quotationId    String
  quotation      Quotation @relation(fields: [quotationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  revisionNumber Int
  snapshotJson   String    @db.NVarChar(Max)  // full quotation+items JSON at time of clone
  createdById    String?
  createdBy      User?     @relation("CreatedRevisionSnapshots", fields: [createdById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdAt      DateTime  @default(now())

  @@index([quotationId])
  @@index([revisionNumber])
  @@index([createdById])
}

model QuotationApproval {
  id           String    @id @default(uuid())
  quotationId  String
  quotation    Quotation @relation(fields: [quotationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  requestedById String?
  requestedBy  User?     @relation("RequestedQuotationApprovals", fields: [requestedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  approverId   String?
  approver     User?     @relation("QuotationApprover", fields: [approverId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  status       String    @default("Pending")  // Pending | Approved | Rejected
  discountPercent Float  @default(0)
  notes        String?   @db.NVarChar(Max)
  decidedAt    DateTime?
  createdAt    DateTime  @default(now())

  @@index([quotationId])
  @@index([status])
  @@index([approverId])
  @@index([requestedById])
}

model OpportunityContact {
  id              String   @id @default(uuid())
  dealId          String
  deal            Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  contactId       String
  contact         Contact  @relation(fields: [contactId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  stakeholderRole String   @default("Influencer")  // Decision Maker | Technical Evaluator | Influencer | Gatekeeper | Finance Approver
  isPrimary       Boolean  @default(false)
  addedAt         DateTime @default(now())

  @@unique([dealId, contactId])
  @@index([dealId])
  @@index([contactId])
}

model VisitAttendee {
  id             String          @id @default(uuid())
  marketingVisitId String
  marketingVisit MarketingVisit  @relation(fields: [marketingVisitId], references: [id], onDelete: Cascade)
  contactId      String?
  contactName    String?         // fallback if no Contact record
  addedAt        DateTime        @default(now())

  @@index([marketingVisitId])
  @@index([contactId])
}

model TaxMaster {
  id            String   @id @default(uuid())
  taxName       String
  taxPercent    Float
  hsnCode       String?
  effectiveFrom DateTime @default(now())
  isActive      Boolean  @default(true)
  companyId     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([isActive])
  @@index([hsnCode])
  @@index([companyId])
}

// ─── Phase 4: Activities, Tasks & Follow Ups ────────────────────────────────────

model ActivityAttendee {
  id                String  @id @default(uuid())
  communicationLogId String
  communicationLog  CommunicationLog @relation(fields: [communicationLogId], references: [id], onDelete: Cascade)
  contactId         String?
  contact           Contact? @relation(fields: [contactId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  userId            String?
  user              User?    @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  addedAt           DateTime @default(now())

  @@index([communicationLogId])
  @@index([contactId])
  @@index([userId])
}

model TaskComment {
  id          String   @id @default(uuid())
  taskId      String
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  commentText String   @db.NVarChar(Max)
  createdAt   DateTime @default(now())

  @@index([taskId])
  @@index([userId])
  @@index([createdAt])
}

model PipelineStageMaster {
  id                 String   @id @default(uuid())
  stageName          String   @unique
  displayName        String
  displayOrder       Int      @default(0)
  probabilityPercent Int      @default(0)
  isActive           Boolean  @default(true)
  isClosedStage      Boolean  @default(false)
  companyId          String?
  company            Company? @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([companyId])
  @@index([displayOrder])
  @@index([isActive])
}

model ReportSchedule {
  id              String   @id @default(uuid())
  reportId        String   // "leads" | "opportunities" | "quotations" | "rfqs" | "follow-ups" | "visits"
  frequency       String   // "Daily" | "Weekly" | "Monthly"
  format          String   // "PDF" | "Excel" | "EmailBody"
  recipientIds    String   @db.NVarChar(Max) // JSON array of user IDs
  filtersJson     String?  @db.NVarChar(Max) // JSON of applied filters
  isActive        Boolean  @default(true)
  lastRunAt       DateTime?
  createdById     String
  createdBy       User     @relation("CreatedReportSchedules", fields: [createdById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  companyId       String?
  company         Company? @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([reportId])
  @@index([createdById])
  @@index([companyId])
}

model ReportExportLog {
  id              String   @id @default(uuid())
  reportId        String
  exportedById    String
  exportedBy      User     @relation("ExportedReports", fields: [exportedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  filtersJson     String?  @db.NVarChar(Max)
  format          String   // "excel" | "pdf"
  companyId       String?
  company         Company? @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  exportedAt      DateTime @default(now())

  @@index([reportId])
  @@index([exportedById])
  @@index([companyId])
}

  customerId           String
  contactId            String?
  productId            String?
  status               String             @default("New")
  receivedDate         DateTime           @default(now())
  requirementDetails   String?            @db.NVarChar(Max)
  targetPrice          Float?
  deliveryDate         DateTime?
  quantity             Float?
  assignedUserId       String?
  notes                String?            @db.NVarChar(Max)

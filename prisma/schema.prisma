  companyId                String?
  deletedAt                DateTime?
  deletedById              String?
  createdAt                DateTime                    @default(now())
  updatedAt                DateTime                    @updatedAt
  deliveryTerms            String?                     @db.NVarChar(Max)
  freightTerms             String?
  leadTimeDays             Int?
  paymentTerms             String?                     @db.NVarChar(Max)
  pdfUrl                   String?                     @db.NVarChar(Max)

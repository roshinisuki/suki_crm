// ─── LOCAL DEVELOPMENT SCHEMA (MySQL) ────────────────────────────────────────
// Used when DB_PROVIDER=mysql (or NODE_ENV=development)
// Connection string format: mysql://user:password@localhost:3306/database

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
  output     = "../node_modules/.prisma/client"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id                    String    @id @default(uuid())
  email                 String    @unique
  name                  String
  passwordHash          String
  role                  String    @default("SalesExecutive")
  department            String? // Sales | Technical | Production | Quality | Management — Variant 3
  userType              String    @default("internal") // "internal" | "customer"
  phone                 String?
  profilePhoto          String?   @db.NVarChar(Max)
  isActive              Boolean   @default(true)
  isFirstLogin          Boolean   @default(true)
  otpCode               String?
  otpExpiry             DateTime?
  otpAttempts           Int       @default(0)
  resetToken            String?   @db.NVarChar(Max)
  resetTokenExpiry      DateTime?
  loginAttempts         Int       @default(0)
  lockedUntil           DateTime?
  lastLoginAt           DateTime?
  invitedBy             String?
  invitedAt             DateTime?
  rememberMe            Boolean   @default(false)
  lastActivityAt        DateTime?
  activationToken       String?   @db.NVarChar(Max)
  activationTokenExpiry DateTime?
  passwordSetAt         DateTime?
  theme                 String    @default("ember") // ember | ocean | forest | obsidian
  themeMode             String    @default("light") // light | dark
  preferredCurrency     String    @default("INR") // INR | USD | EUR — display currency preference
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  // Multi-Tenancy
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  // Soft Delete
  deletedAt   DateTime?
  deletedById String?

  marketingVisits     MarketingVisit[]        @relation("ExecutiveVisits")
  customerVisits      CustomerVisit[]
  hostedVisitors      Visitor[]
  auditLogs           AuditLog[]
  passwordResetTokens PasswordResetToken[]
  assignedFollowUps   FollowUp[]              @relation("AssignedFollowUps")
  completedFollowUps  FollowUp[]              @relation("CompletedFollowUps")
  assignedCustomers   Customer[]              @relation("AssignedCustomers")
  notifications       Notification[]
  notificationPrefs   NotificationPreference?
  assignedDeals       Deal[]
  callLogs            CallLog[]
  dealStageHistories  DealStageHistory[]

  // Enterprise relations
  leads              Lead[]
  onboardedCustomers Customer[]         @relation("OnboardedCustomers")
  approvedVisits     MarketingVisit[]   @relation("ApprovedVisits")
  assignedTickets    SupportTicket[]
  communicationLogs  CommunicationLog[]

  // Lead SLA Ownership History
  leadOwnerHistoryFrom      LeadOwnerHistory[] @relation("OwnerHistoryFrom")
  leadOwnerHistoryTo        LeadOwnerHistory[] @relation("OwnerHistoryTo")
  leadOwnerHistoryChangedBy LeadOwnerHistory[] @relation("OwnerHistoryChangedBy")

  approvedDiscounts  Deal[]            @relation("ApprovedDiscounts")
  requestedApprovals ApprovalHistory[] @relation("RequestedApprovals")
  resolvedApprovals  ApprovalHistory[] @relation("ResolvedApprovals")
  proposalVersions   ProposalVersion[]

  // Polymorphic Notes
  createdNotes Note[] @relation("CreatedNotes")

  // Contacts & Tasks
  Contact Contact[]
  Task    Task[]

  // Variant 2 relations
  createdQuotations Quotation[]     @relation("CreatedQuotations")
  forecastEntries   ForecastEntry[]
  rfqs              RFQ[]           @relation("AssignedRFQs")

  // Variant 3 relations
  assignedSamples        SampleRequest[]       @relation("AssignedSamples")
  approvedSamples        SampleRequest[]       @relation("ApprovedSamples")
  rejectedSamples        SampleRequest[]       @relation("RejectedSamples")
  sampleDeletedBy        SampleRequest[]       @relation("SampleDeletedBy")
  assignedNegotiations   Negotiation[]         @relation("AssignedNegotiations")
  approvedNegotiations   Negotiation[]         @relation("ApprovedNegotiations")
  negotiationDeletedBy   Negotiation[]         @relation("NegotiationDeletedBy")
  negotiationRevisions   NegotiationRevision[] @relation("NegotiationRevisions")
  assignedPurchaseOrders PurchaseOrder[]       @relation("AssignedPurchaseOrders")
  approvedPurchaseOrders PurchaseOrder[]       @relation("ApprovedPurchaseOrders")
  purchaseOrderDeletedBy PurchaseOrder[]       @relation("PurchaseOrderDeletedBy")
  documents              CRMDocument[]         @relation("UploadedDocuments")
  documentDeletedBy      CRMDocument[]         @relation("DocumentDeletedBy")
  approvalRequests       ApprovalRequest[]     @relation("ApprovalRequestRequestedBy")
  approvalResolvedBy     ApprovalRequest[]     @relation("ApprovalRequestResolvedBy")

  // Variant 4 relations
  territoriesAssigned      Territory[]            @relation("AssignedTerritories")
  salesTargetsAssigned     SalesTarget[]          @relation("AssignedSalesTargets")
  keyAccountsManaged       KeyAccount[]           @relation("ManagedKeyAccounts")
  lostDealAnalysesRecorded LostDealAnalysis[]     @relation("RecordedLostDealAnalyses")

  @@index([role])
  @@index([isActive])
  @@index([userType])
  @@index([companyId])
}

model Customer {
  id                String    @id @default(uuid())
  customerCode      String    @unique
  name              String
  email             String?   @unique
  phone             String?
  city              String?
  status            String    @default("Prospect")
  assignedUserId    String?
  assignedUser      User?     @relation("AssignedCustomers", fields: [assignedUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  onboardingStatus  String    @default("Pending")
  onboardedAt       DateTime?
  onboardedById     String?
  onboardedBy       User?     @relation("OnboardedCustomers", fields: [onboardedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  convertedFromLead String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Multi-Tenancy
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  // Soft Delete
  deletedAt   DateTime?
  deletedById String?

  subscriptions     Subscription[]
  marketingVisits   MarketingVisit[]
  customerVisits    CustomerVisit[]
  followUps         FollowUp[]
  deals             Deal[]
  callLogs          CallLog[]
  communicationLogs CommunicationLog[]
  contacts          Contact[]
  invoices          Invoice[]
  supportTickets    SupportTicket[]
  proposals         Proposal[]

  // Variant 2 relations
  rfqs       RFQ[]
  quotations Quotation[]

  // Variant 3 relations
  samples        SampleRequest[]
  negotiations   Negotiation[]
  purchaseOrders PurchaseOrder[]
  documents      CRMDocument[]

  // Variant 4 relations
  territoryAccounts TerritoryAccount[]
  keyAccounts        KeyAccount[]

  // Keep leadSource for history if converted
  leadSource String?

  @@index([customerCode])
  @@index([status])
  @@index([assignedUserId])
  @@index([companyId])
}

model Subscription {
  id         String   @id @default(uuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])
  planName   String
  startDate  DateTime
  endDate    DateTime
  status     String   @default("Active")
  notes      String?  @db.NVarChar(Max)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Renewal Alert Sentinels (prevent duplicate notifications)
  renewalAlertSent30 Boolean @default(false)
  renewalAlertSent7  Boolean @default(false)

  // Multi-Tenancy
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  // Soft Delete
  deletedAt   DateTime?
  deletedById String?

  @@index([customerId])
  @@index([status])
  @@index([endDate])
  @@index([companyId])
}

model CustomerVisit {
  id               String    @id @default(uuid())
  customerId       String
  customer         Customer  @relation(fields: [customerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  hostedBy         String
  host             User      @relation(fields: [hostedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  purpose          String
  checkInTime      DateTime  @default(now())
  checkOutTime     DateTime?
  meetingSummary   String?   @db.NVarChar(Max)
  outcome          String?
  customerDecision String?
  rejectionReason  String?   @db.NVarChar(Max)
  nextMeetingDate  DateTime?
  nextMeetingNotes String?   @db.NVarChar(Max)
  status           String    @default("CHECKED_IN")
  priority         String    @default("Normal")
  meetingType      String?
  source           String?
  agenda           String?   @db.NVarChar(Max)
  department       String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Multi-Tenancy
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  // Soft Delete
  deletedAt   DateTime?
  deletedById String?

  @@index([customerId])
  @@index([hostedBy])
  @@index([status])
  @@index([companyId])
}

model MarketingVisit {
  id                 String    @id @default(uuid())
  executiveId        String
  executive          User      @relation("ExecutiveVisits", fields: [executiveId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  customerId         String?
  customer           Customer? @relation(fields: [customerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  leadId             String?
  lead               Lead?     @relation(fields: [leadId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  checkIn            DateTime?
  checkOut           DateTime?
  checkInLat         Float?
  checkInLng         Float?
  checkOutLat        Float?
  checkOutLng        Float?
  checkInPhoto       String?
  remarks            String?   @db.NVarChar(Max)
  nextMeetingDate    DateTime?
  createdAt          DateTime  @default(now())
  purpose            String?
  meetingDescription String?   @db.NVarChar(Max)
  outcome            String?
  customerDecision   String?
  rejectionReason    String?   @db.NVarChar(Max)
  nextMeetingNotes   String?   @db.NVarChar(Max)
  status             String    @default("REQUESTED") // REQUESTED, APPROVED, CHECKED_IN, COMPLETED, REJECTED
  approvedByUserId   String?
  approvedByUser     User?     @relation("ApprovedVisits", fields: [approvedByUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  approvedAt         DateTime?
  updatedAt          DateTime? @updatedAt

  // Multi-Tenancy
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  // Soft Delete
  deletedAt   DateTime?
  deletedById String?

  @@index([executiveId])
  @@index([customerId])
  @@index([leadId])
  @@index([nextMeetingDate])
  @@index([status])
  @@index([companyId])
}

model Visitor {
  id           String    @id @default(uuid())
  visitorName  String
  company      String
  visitorEmail String?
  visitorPhone String
  purpose      String
  inTime       DateTime  @default(now())
  outTime      DateTime?
  hostUserId   String
  host         User      @relation(fields: [hostUserId], references: [id], onDelete: Cascade)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([hostUserId])
  @@index([inTime])
}

model AuditLog {
  id      String  @id @default(uuid())
  userId  String?
  user    User?   @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  module  String
  action  String
  details String? @db.NVarChar(Max)

  // Phase 2: State-Diff Audit Fields
  resourceId    String? // ID of the entity that changed (lead ID, customer ID, etc.)
  previousState String? @db.NVarChar(Max) // Snapshot of entity before the change
  newState      String? @db.NVarChar(Max) // Snapshot of entity after the change
  ipAddress     String? // Client IP address extracted from request headers
  userAgent     String? @db.NVarChar(Max) // Browser/client user agent string
  severity      String  @default("INFO") // INFO | WARN | HIGH | CRITICAL

  // Multi-Tenancy
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  timestamp DateTime @default(now())

  @@index([userId])
  @@index([module])
  @@index([timestamp])
  @@index([severity])
  @@index([resourceId])
  @@index([companyId])
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  otp       String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}

model FollowUp {
  id              String    @id @default(uuid())
  customerId      String?
  customer        Customer? @relation(fields: [customerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  leadId          String?
  lead            Lead?     @relation(fields: [leadId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  assignedUserId  String
  assignedUser    User      @relation("AssignedFollowUps", fields: [assignedUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  nextMeetingDate DateTime
  remarks         String?   @db.NVarChar(Max)
  status          String    @default("Pending")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // New fields for inbound/outbound workflow integration
  visitId     String?
  visitType   String? // INBOUND / OUTBOUND
  completedAt DateTime?
  notes       String?   @db.NVarChar(Max)

  // Advanced tracking fields
  dueDate         DateTime?
  reminderAt      DateTime?
  completedById   String?
  completedBy     User?     @relation("CompletedFollowUps", fields: [completedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  sourceType      String? // e.g. "LEAD_INGESTION", "VISIT_CHECKOUT", "MANUAL"
  sourceId        String?
  completionNotes String?   @db.NVarChar(Max)
  priority        String    @default("Medium") // Low, Medium, High
  escalationLevel Int       @default(0)
  autoCreated     Boolean   @default(false)
  type            String? // "Call" | "Meeting" | "Note" — links to activity type

  // Activities linked to this follow-up
  communicationLogs CommunicationLog[]

  // Multi-Tenancy
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  // Soft Delete
  deletedAt   DateTime?
  deletedById String?

  @@index([customerId])
  @@index([leadId])
  @@index([assignedUserId])
  @@index([status])
  @@index([nextMeetingDate])
  @@index([completedById])
  @@index([companyId])
  @@index([type])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String   @db.NVarChar(Max)
  type      String // "follow_up", "visit", "system"
  link      String? // Optional URL for action linkage
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

model NotificationPreference {
  id                  Int     @id @default(autoincrement())
  userId              String  @unique
  emailFollowUp       Boolean @default(true)
  emailVisitorCheckIn Boolean @default(false)
  inAppVisitUpdate    Boolean @default(true)
  notifyOnDealStatus  Boolean @default(true)
  notifyOnCallLog     Boolean @default(true)
  user                User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Deal {
  id                String             @id @default(uuid())
  dealName          String
  customerId        String
  customer          Customer           @relation(fields: [customerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  dealValue         Float
  expectedCloseDate DateTime
  assignedUserId    String?
  assignedUser      User?              @relation(fields: [assignedUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  notes             String?            @db.NVarChar(Max)
  status            String             @default("Active")
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  stageHistories    DealStageHistory[]

  // Discount & Locking fields
  discountPercent      Float   @default(0.0)
  discountStatus       String  @default("None") // "None" | "Pending" | "Approved" | "Rejected"
  isLocked             Boolean @default(false)
  discountNotes        String? @db.NVarChar(Max)
  discountApprovedById String?
  discountApprovedBy   User?   @relation("ApprovedDiscounts", fields: [discountApprovedById], references: [id], onDelete: NoAction, onUpdate: NoAction)

  lostReason        String?            @db.NVarChar(Max)
  approvalRemarks   String?            @db.NVarChar(Max)
  approvalHistory   ApprovalHistory[]
  proposals         Proposal[]
  opportunityDetail OpportunityDetail?

  // Variant 2 relations
  quotations Quotation[]
  tasks      Task[]

  // Variant 3 relations
  negotiations   Negotiation[]
  purchaseOrders PurchaseOrder[]

  // Variant 4 relations
  lostDealAnalysis LostDealAnalysis?

  // Multi-Tenancy
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  // Soft Delete
  deletedAt   DateTime?
  deletedById String?

  // Forecast & Renewal details
  forecastEntryDate DateTime?
  renewalDate       DateTime?

  @@index([customerId])
  @@index([assignedUserId])
  @@index([status])
  @@index([companyId])
}

model OpportunityDetail {
  id     String @id @default(uuid())
  dealId String @unique
  deal   Deal   @relation(fields: [dealId], references: [id], onDelete: Cascade)

  // ── Requirement Gathering (Discovery) Fields ──
  currentChallenges String? @db.NVarChar(Max)
  painPoints        String? @db.NVarChar(Max)
  painPointsList    String? @db.NVarChar(Max) // JSON string of checkboxes

  requiredFeatures String? @db.NVarChar(Max) // Legacy
  modulesRequired  String? @db.NVarChar(Max) // JSON string of checkboxes

  deploymentType       String? // Cloud SaaS, On-Premise
  integrationsRequired String? @db.NVarChar(Max) // JSON string of checkboxes

  userCountSales    Int?
  userCountManagers Int?
  userCountAdmins   Int?

  budgetRange        String?
  timeline           String?
  procurementProcess String?

  decisionMaker  String?
  influencer     String?
  budgetOwner    String?
  expectedGoLive DateTime?

  currentVendor        String?
  competitorsEvaluated String? @db.NVarChar(Max)

  // ── Pre-Sales Review Fields ──
  proposedSolution     String? @db.NVarChar(Max)
  scopeClassification  String?
  estimatedDuration    String?
  developmentEffort    String?
  implementationEffort String?
  supportRequirements  String?

  // ── Meeting Scheduled Fields ──
  meetingType         String?
  meetingMode         String?
  meetingDate         DateTime?
  meetingStatus       String?
  meetingDuration     Int?
  meetingParticipants String?   @db.NVarChar(Max)
  meetingLocation     String?   @db.NVarChar(Max)
  meetingAgenda       String?   @db.NVarChar(Max)
  meetingOutcome      String?   @db.NVarChar(Max)

  // ── Demo Conducted Fields ──
  demoType            String?
  demoDate            DateTime?
  demoPresenter       String?
  demoDuration        Int?
  demoAttendees       String?   @db.NVarChar(Max)
  demoCustomerRating  String?
  demoInterestLevel   String?
  demoQuestionsRaised String?   @db.NVarChar(Max)

  // ── Rejected Demo Fields ──
  demoRejectionReason  String?
  demoRejectionRemarks String? @db.NVarChar(Max)
  demoCompetitorName   String?

  // ── Business Requirements Fields ──
  businessNeed        String? @db.NVarChar(Max)
  expectedOutcome     String? @db.NVarChar(Max)
  requiredDepartments String? @db.NVarChar(Max)
  numberOfUsers       Int?
  urgencyPriority     String?
  businessGoals       String? @db.NVarChar(Max)
  successCriteria     String? @db.NVarChar(Max)

  // ── Technical Requirements Fields ──
  existingSoftwareStack String? @db.NVarChar(Max)
  securityCompliance    String? @db.NVarChar(Max)
  userRolesPermissions  String? @db.NVarChar(Max)
  reportingRequirements String? @db.NVarChar(Max)
  dataMigrationRequired String?
  customizationNeeded   String? @db.NVarChar(Max)
  apiThirdPartyReqs     String? @db.NVarChar(Max)
  technicalConstraints  String? @db.NVarChar(Max)
  itTeamNotes           String? @db.NVarChar(Max)

  // ── Commercial Info Fields ──
  expectedBudget       Float?
  finalDiscussedBudget Float?
  pricingModel         String?
  licenseCount         Int?
  paymentTerms         String?
  billingCycle         String?
  competitorInfo       String? @db.NVarChar(Max)
  commercialRisks      String? @db.NVarChar(Max)
  discountRequested    Float?
  proposalValue        Float?
  negotiationNotes     String? @db.NVarChar(Max)
  probability          Int?

  // ── Internal Notes Fields ──
  internalSalesNotes String? @db.NVarChar(Max)
  presalesNotes      String? @db.NVarChar(Max)
  objections         String? @db.NVarChar(Max)
  followUpSummary    String? @db.NVarChar(Max)
  risksBlockers      String? @db.NVarChar(Max)
  nextSteps          String? @db.NVarChar(Max)
  managementNotes    String? @db.NVarChar(Max)

  // ── Customer Info (editable) ──
  companyName          String?
  industry             String?
  contactPerson        String?
  email                String?
  phone                String?
  employeeCount        Int?
  approvalProcess      String? @db.NVarChar(Max)
  buyingAuthorityNotes String? @db.NVarChar(Max)

  // ── Requirement Gathering completion ──
  requirementCompletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CallLog {
  id         String    @id @default(uuid())
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  leadId     String?
  lead       Lead?     @relation(fields: [leadId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  notes      String?   @db.NVarChar(Max)
  duration   Int? // duration in seconds
  userId     String
  user       User      @relation(fields: [userId], references: [id])
  timestamp  DateTime  @default(now())

  @@index([customerId])
  @@index([leadId])
  @@index([userId])
}

model DealStageHistory {
  id          Int      @id @default(autoincrement())
  dealId      String
  deal        Deal     @relation(fields: [dealId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  fromStatus  String?
  toStatus    String
  changedById String
  changedBy   User     @relation(fields: [changedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  changedAt   DateTime @default(now())

  @@index([dealId])
  @@index([changedById])
}

model SystemConfig {
  key   String @id
  value String
}

model Lead {
  id             String   @id @default(uuid())
  leadCode       String   @unique
  name           String
  email          String?  @unique
  phone          String?
  city           String?
  status         String   @default("New")
  assignedUserId String?
  assignedUser   User?    @relation(fields: [assignedUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  leadSource     String   @default("Website")
  notes          String?  @db.NVarChar(Max)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // SLA Tracking Fields
  slaStatus           String    @default("Pending")
  slaResponseDeadline DateTime? // Set to createdAt + 15 min on ingestion
  firstRespondedAt    DateTime? // Set when status first moves away from New
  escalationLevel     Int       @default(0) // 0=None, 1=48h Manager Alert, 2=72h Auto-Reassign
  lastInteractionAt   DateTime  @default(now())

  // Qualification Fields (for SQL promotion)
  budgetAsked     String?
  timelineAsked   String?
  isDecisionMaker Boolean @default(false)
  isGenuine       Boolean @default(false)

  // Multi-Tenancy
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  // Soft Delete
  deletedAt   DateTime?
  deletedById String?

  communicationLogs CommunicationLog[]
  marketingVisits   MarketingVisit[]
  followUps         FollowUp[]
  callLogs          CallLog[]
  ownerHistory      LeadOwnerHistory[]

  @@index([status])
  @@index([assignedUserId])
  @@index([slaStatus])
  @@index([escalationLevel])
  @@index([companyId])
}

model LeadOwnerHistory {
  id            String   @id @default(uuid())
  leadId        String
  lead          Lead     @relation(fields: [leadId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  fromUserId    String?
  fromUser      User?    @relation("OwnerHistoryFrom", fields: [fromUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  toUserId      String?
  toUser        User?    @relation("OwnerHistoryTo", fields: [toUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  changedById   String? // Null = SYSTEM auto-reassignment
  changedByUser User?    @relation("OwnerHistoryChangedBy", fields: [changedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  reason        String?  @db.NVarChar(Max)
  timestamp     DateTime @default(now())

  @@index([leadId])
  @@index([fromUserId])
  @@index([toUserId])
  @@index([changedById])
}

model CommunicationLog {
  id           String    @id @default(uuid())
  customerId   String?
  customer     Customer? @relation(fields: [customerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  leadId       String?
  lead         Lead?     @relation(fields: [leadId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  dealId       String?
  channel      String // "Call" | "Meeting" | "Note" | "Email" | "WhatsApp"
  direction    String // "Inbound" | "Outbound"
  status       String // e.g. "Completed", "Scheduled", "NoAnswer", "Delivered", "Failed"
  content      String    @db.NVarChar(Max)
  sentByUserId String?
  sentByUser   User?     @relation(fields: [sentByUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  sentAt       DateTime  @default(now())

  // Call/Meeting specific fields
  duration    Int? // minutes
  location    String? // for meetings
  mode        String? // "In-person" | "Virtual"
  agenda      String?   @db.NVarChar(Max)
  outcome     String?   @db.NVarChar(Max)
  meetingDate DateTime?

  // Follow-Up linking — each activity can be linked to a follow-up
  followUpId String?
  followUp   FollowUp? @relation(fields: [followUpId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  // Multi-Tenancy
  companyId String?

  // Soft Delete
  deletedAt   DateTime?
  deletedById String?

  @@index([customerId])
  @@index([leadId])
  @@index([sentByUserId])
  @@index([channel])
  @@index([companyId])
  @@index([followUpId])
}

model Invoice {
  id            String    @id @default(uuid())
  invoiceNumber String    @unique
  customerId    String
  customer      Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  amount        Float
  status        String    @default("Unpaid")
  issueDate     DateTime  @default(now())
  dueDate       DateTime
  paidAt        DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([customerId])
  @@index([status])
}

model SupportTicket {
  id             String   @id @default(uuid())
  ticketNumber   String   @unique
  customerId     String
  customer       Customer @relation(fields: [customerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  title          String
  description    String   @db.NVarChar(Max)
  priority       String   @default("Medium")
  status         String   @default("Open")
  assignedUserId String?
  assignedUser   User?    @relation(fields: [assignedUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([customerId])
  @@index([status])
  @@index([assignedUserId])
}

model Proposal {
  id             String   @id @default(uuid())
  proposalNumber String   @unique
  customerId     String
  customer       Customer @relation(fields: [customerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  dealId         String?
  deal           Deal?    @relation(fields: [dealId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  title          String
  description    String?  @db.NVarChar(Max)
  value          Float    @default(0.0)
  validUntil     DateTime
  proposalPdfUrl String?  @db.NVarChar(Max)
  status         String   @default("Draft") // "Draft" | "Sent" | "CustomerReviewing" | "RevisionRequested" | "Accepted" | "Rejected" | "Expired"
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  versions ProposalVersion[]

  // Multi-Tenancy
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  // Soft Delete
  deletedAt   DateTime?
  deletedById String?

  @@index([customerId])
  @@index([dealId])
  @@index([status])
  @@index([companyId])
}

model ProposalVersion {
  id             String   @id @default(uuid())
  proposalId     String
  proposal       Proposal @relation(fields: [proposalId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  versionNumber  Int
  title          String
  description    String?  @db.NVarChar(Max)
  value          Float
  validUntil     DateTime
  proposalPdfUrl String?  @db.NVarChar(Max)
  status         String
  changedById    String
  changedBy      User     @relation(fields: [changedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdAt      DateTime @default(now())

  @@index([proposalId])
}

model ApprovalHistory {
  id              String    @id @default(uuid())
  dealId          String?
  deal            Deal?     @relation(fields: [dealId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  requestedById   String
  requestedBy     User      @relation("RequestedApprovals", fields: [requestedById], references: [id])
  resolvedById    String?
  resolvedBy      User?     @relation("ResolvedApprovals", fields: [resolvedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  discountPercent Float     @default(0)
  status          String // Pending, Approved, Rejected
  remarks         String?   @db.NVarChar(Max)
  previousStatus  String? // Deal status captured before locking (for exact rollback on rejection)
  // Variant 3 — generic approval fields
  approvalType    String? // Discount | Negotiation | PO | Quotation
  entityType      String? // Deal | Negotiation | PurchaseOrder | Quotation
  entityId        String?
  createdAt       DateTime  @default(now())
  resolvedAt      DateTime?

  // Soft Delete
  deletedAt   DateTime?
  deletedById String?

  @@index([dealId])
  @@index([entityType, entityId])
  @@index([approvalType])
  @@index([status])
}

model Company {
  id           String   @id @default(uuid())
  name         String   @unique
  variant      Int      @default(1) // CRM variant: 1, 2, 3...
  baseCurrency String   @default("INR") // Base currency for all transactions (INR | USD | EUR)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  users             User[]
  leads             Lead[]
  customers         Customer[]
  deals             Deal[]
  proposals         Proposal[]
  followUps         FollowUp[]
  marketingVisits   MarketingVisit[]
  customerVisits    CustomerVisit[]
  auditLogs         AuditLog[]
  notes             Note[]
  subscriptions     Subscription[]
  leadSources       LeadSource[]
  products          Product[]
  productCategories ProductCategory[]
  rfqs              RFQ[]
  quotations        Quotation[]
  forecastEntries   ForecastEntry[]
  pipelineStages    PipelineStage[]
  SampleRequest     SampleRequest[]
  Negotiation       Negotiation[]
  PurchaseOrder     PurchaseOrder[]
  CRMDocument       CRMDocument[]
  ApprovalRequest   ApprovalRequest[]
  emailTemplates    EmailTemplate[]
  whatsappTemplates WhatsAppTemplate[]

  // Variant 4 relations
  competitors       Competitor[]
  lossReasons       LossReason[]
  territories       Territory[]
  salesTargets      SalesTarget[]
  keyAccounts       KeyAccount[]
  lostDealAnalyses  LostDealAnalysis[]
}

model LeadSource {
  id        String   @id @default(uuid())
  name      String   @unique
  isActive  Boolean  @default(true)
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdAt DateTime @default(now())
}

model Note {
  id          String    @id @default(uuid())
  content     String    @db.NVarChar(Max)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  createdById String
  createdBy   User      @relation("CreatedNotes", fields: [createdById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  entityType  String // "LEAD" | "CONTACT" | "VISIT" | "DEAL" | "PROPOSAL" | "NEGOTIATION"
  entityId    String // Target record UUID
  deletedAt   DateTime?
  deletedById String?
  companyId   String?
  company     Company?  @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([entityType, entityId])
  @@index([createdById])
  @@index([companyId])
}

model Contact {
  id          String    @id @default(uuid())
  contactCode String?
  name        String
  email       String?
  phone       String?
  company     String?
  title       String?
  designation String?
  status      String    @default("Active")
  contactType String    @default("Technical") // Technical | Purchase | Finance | Management
  isPrimary   Boolean   @default(false)
  notes       String?   @db.NVarChar(Max)
  customerId  String?
  customer    Customer? @relation(fields: [customerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  ownerId     String
  User        User      @relation(fields: [ownerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Multi-Tenancy
  companyId String?

  // Soft Delete
  deletedAt   DateTime?
  deletedById String?

  Task Task[]

  // Variant 2 relations
  rfqs       RFQ[]
  quotations Quotation[]

  // Variant 3 relations
  negotiations   Negotiation[]
  purchaseOrders PurchaseOrder[]
  samples        SampleRequest[]

  @@index([ownerId])
  @@index([status])
  @@index([customerId])
  @@index([contactType])
  @@index([companyId])
}

model Task {
  id          String    @id @default(uuid())
  taskCode    String?
  title       String
  description String?   @db.NVarChar(Max)
  status      String    @default("Open")
  priority    String    @default("Medium")
  dueDate     DateTime?
  contactId   String?
  Contact     Contact?  @relation(fields: [contactId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  dealId      String?
  Deal        Deal?     @relation(fields: [dealId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  assignedTo  String
  User        User      @relation(fields: [assignedTo], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Multi-Tenancy
  companyId String?

  // Soft Delete
  deletedAt   DateTime?
  deletedById String?

  @@index([assignedTo])
  @@index([contactId])
  @@index([dealId])
  @@index([status])
  @@index([companyId])
}

// ─── Variant 2 Models ─────────────────────────────────────────────────────

model ProductCategory {
  id          String    @id @default(uuid())
  name        String
  description String?
  isActive    Boolean   @default(true)
  companyId   String?
  company     Company?  @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([companyId])
  @@index([isActive])
}

model Product {
  id                 String                 @id @default(uuid())
  productCode        String                 @unique
  name               String
  categoryId         String?
  category           ProductCategory?       @relation(fields: [categoryId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  description        String?                @db.NVarChar(Max)
  unit               String?
  basePrice          Float?
  isActive           Boolean                @default(true)
  datasheetUrl       String?                @db.NVarChar(Max)
  brochureUrl        String?                @db.NVarChar(Max)
  // Variant 3 fields
  productType        String? // FinishedGood | RawMaterial | Component | SubAssembly | Consumable
  minOrderQuantity   Float?
  companyId          String?
  company            Company?               @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  specifications     ProductSpecification[]
  rfqs               RFQ[]
  quotationItems     QuotationItem[]
  // Variant 3 relations
  samples            SampleRequest[]
  purchaseOrderItems PurchaseOrderItem[]
  deletedAt          DateTime?
  deletedById        String?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt

  @@index([companyId])
  @@index([categoryId])
  @@index([isActive])
}

model ProductSpecification {
  id           String   @id @default(uuid())
  productId    String
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  specKey      String
  specValue    String
  unit         String?
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([productId])
}

model RFQ {
  id                   String          @id @default(uuid())
  rfqCode              String          @unique
  customerId           String
  customer             Customer        @relation(fields: [customerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  contactId            String?
  contact              Contact?        @relation(fields: [contactId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  productId            String?
  product              Product?        @relation(fields: [productId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  status               String          @default("New")
  receivedDate         DateTime        @default(now())
  requirementDetails   String?         @db.NVarChar(Max)
  targetPrice          Float?
  deliveryDate         DateTime?
  quantity             Float?
  assignedUserId       String?
  assignedUser         User?           @relation("AssignedRFQs", fields: [assignedUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  notes                String?         @db.NVarChar(Max)
  // Variant 3 field
  expectedDeliveryDate DateTime?
  companyId            String?
  company              Company?        @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  deletedAt            DateTime?
  deletedById          String?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  quotations           Quotation[]
  // Variant 3 relations
  samples              SampleRequest[]

  @@index([customerId])
  @@index([status])
  @@index([assignedUserId])
  @@index([companyId])
}

model Quotation {
  id                 String          @id @default(uuid())
  quotationCode      String          @unique
  rfqId              String?
  rfq                RFQ?            @relation(fields: [rfqId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  customerId         String
  customer           Customer        @relation(fields: [customerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  contactId          String?
  contact            Contact?        @relation(fields: [contactId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  dealId             String?
  deal               Deal?           @relation(fields: [dealId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  status             String          @default("Draft")
  validUntil         DateTime
  totalAmount        Float           @default(0)
  discountPercent    Float           @default(0)
  finalAmount        Float           @default(0)
  termsAndConditions String?         @db.NVarChar(Max)
  sentAt             DateTime?
  acceptedAt         DateTime?
  rejectedAt         DateTime?
  rejectionReason    String?         @db.NVarChar(Max)
  createdById        String
  createdBy          User            @relation("CreatedQuotations", fields: [createdById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  companyId          String?
  company            Company?        @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  items              QuotationItem[]
  deletedAt          DateTime?
  deletedById        String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  // Variant 3 relations
  negotiations       Negotiation[]
  purchaseOrders     PurchaseOrder[]

  @@index([customerId])
  @@index([status])
  @@index([companyId])
  @@index([rfqId])
}

model QuotationItem {
  id          String    @id @default(uuid())
  quotationId String
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  productId   String?
  product     Product?  @relation(fields: [productId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  description String
  quantity    Float
  unitPrice   Float
  totalPrice  Float
  notes       String?

  @@index([quotationId])
}

model ForecastEntry {
  id             String   @id @default(uuid())
  month          Int
  year           Int
  forecastType   String
  targetAmount   Float
  achievedAmount Float    @default(0)
  assignedUserId String?
  assignedUser   User?    @relation(fields: [assignedUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  notes          String?
  companyId      String?
  company        Company? @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([companyId])
  @@index([year, month])
  @@index([assignedUserId])
}

model PipelineStage {
  id        String   @id @default(uuid())
  name      String
  order     Int
  color     String   @default("#378ADD")
  isActive  Boolean  @default(true)
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdAt DateTime @default(now())

  @@index([companyId])
  @@index([order])
}

// ─── Exchange Rate Cache ──────────────────────────────────────────────────────
// Stores daily exchange rates fetched from external API.
// Rates are relative to base currency (e.g., 1 INR = 0.012 USD).
// Updated daily via cron or on-demand when stale.

model ExchangeRate {
  id            String   @id @default(uuid())
  baseCurrency  String // e.g., "INR"
  quoteCurrency String // e.g., "USD"
  rate          Float // 1 baseCurrency = rate quoteCurrency
  fetchedAt     DateTime @default(now()) // when the rate was fetched from API
  source        String   @default("exchangerate-api") // API source identifier

  @@unique([baseCurrency, quoteCurrency])
  @@index([baseCurrency])
  @@index([fetchedAt])
}

// ============================================================
// VARIANT 3 — Manufacturing CRM Models
// ============================================================

model SampleRequest {
  id               String    @id @default(uuid())
  sampleCode       String    @unique
  customerId       String
  customer         Customer  @relation(fields: [customerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  contactId        String?
  contact          Contact?  @relation(fields: [contactId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  productId        String
  product          Product   @relation(fields: [productId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  rfqId            String?
  rfq              RFQ?      @relation(fields: [rfqId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  status           String    @default("New") // New | UnderReview | SentToCustomer | Approved | Rejected | Revision
  requestDate      DateTime  @default(now())
  sentDate         DateTime?
  approvedDate     DateTime?
  rejectedDate     DateTime?
  revisionDate     DateTime?
  quantity         Float
  specifications   String?   @db.NVarChar(Max)
  customerFeedback String?   @db.NVarChar(Max)
  revisionNotes    String?   @db.NVarChar(Max)
  trackingNumber   String?
  assignedUserId   String?
  assignedUser     User?     @relation("AssignedSamples", fields: [assignedUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  approvedById     String?
  approvedBy       User?     @relation("ApprovedSamples", fields: [approvedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  rejectedById     String?
  rejectedBy       User?     @relation("RejectedSamples", fields: [rejectedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  companyId        String?
  company          Company?  @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  deletedAt        DateTime?
  deletedById      String?
  deletedBy        User?     @relation("SampleDeletedBy", fields: [deletedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([customerId])
  @@index([productId])
  @@index([status])
  @@index([assignedUserId])
  @@index([companyId])
}

model Negotiation {
  id                String                @id @default(uuid())
  negotiationCode   String                @unique
  quotationId       String?
  quotation         Quotation?            @relation(fields: [quotationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  dealId            String?
  deal              Deal?                 @relation(fields: [dealId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  customerId        String
  customer          Customer              @relation(fields: [customerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  contactId         String?
  contact           Contact?              @relation(fields: [contactId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  status            String                @default("Active") // Active | PriceRevision | CommercialDiscussion | PendingApproval | Won | Lost
  initialAmount     Float
  revisedAmount     Float?
  finalAmount       Float?
  discountRequested Float                 @default(0)
  discountApproved  Float?
  customerDemands   String?               @db.NVarChar(Max)
  internalNotes     String?               @db.NVarChar(Max)
  outcome           String? // Won | Lost | Pending
  closedAt          DateTime?
  assignedUserId    String?
  assignedUser      User?                 @relation("AssignedNegotiations", fields: [assignedUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  approvedById      String?
  approvedBy        User?                 @relation("ApprovedNegotiations", fields: [approvedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  companyId         String?
  company           Company?              @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  revisions         NegotiationRevision[]
  deletedAt         DateTime?
  deletedById       String?
  deletedBy         User?                 @relation("NegotiationDeletedBy", fields: [deletedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  PurchaseOrder     PurchaseOrder[]

  @@index([customerId])
  @@index([quotationId])
  @@index([dealId])
  @@index([status])
  @@index([assignedUserId])
  @@index([companyId])
}

model NegotiationRevision {
  id              String      @id @default(uuid())
  negotiationId   String
  negotiation     Negotiation @relation(fields: [negotiationId], references: [id], onDelete: Cascade)
  revisionNumber  Int
  proposedAmount  Float
  discountPercent Float       @default(0)
  reason          String?     @db.NVarChar(Max)
  status          String      @default("Pending") // Pending | Approved | Rejected
  createdById     String
  createdBy       User        @relation("NegotiationRevisions", fields: [createdById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdAt       DateTime    @default(now())

  @@index([negotiationId])
}

model PurchaseOrder {
  id               String              @id @default(uuid())
  poCode           String              @unique
  customerId       String
  customer         Customer            @relation(fields: [customerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  contactId        String?
  contact          Contact?            @relation(fields: [contactId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  negotiationId    String?
  negotiation      Negotiation?        @relation(fields: [negotiationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  quotationId      String?
  quotation        Quotation?          @relation(fields: [quotationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  dealId           String?
  deal             Deal?               @relation(fields: [dealId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  status           String              @default("New") // New | UnderValidation | Approved | Rejected | Closed
  poNumber         String?
  poDate           DateTime?
  expectedDelivery DateTime?
  actualDelivery   DateTime?
  totalAmount      Float               @default(0)
  discountPercent  Float               @default(0)
  finalAmount      Float               @default(0)
  paymentTerms     String?
  deliveryTerms    String?
  shippingAddress  String?             @db.NVarChar(Max)
  billingAddress   String?             @db.NVarChar(Max)
  notes            String?             @db.NVarChar(Max)
  poDocumentUrl    String?             @db.NVarChar(Max)
  specialInstructions String?          @db.NVarChar(Max)
  validationChecklist String?          @db.NVarChar(Max) // JSON: {customerVerified, contactVerified, productsConfirmed, documentUploaded, amountMatches}
  erpSyncStatus    String?             // Pending | Synced | Failed
  erpReferenceNumber String?
  erpSyncedAt      DateTime?
  erpPayload       String?             @db.NVarChar(Max) // JSON string
  erpResponse      String?             @db.NVarChar(Max) // JSON string
  approvedAt       DateTime?
  approvedById     String?
  approvedBy       User?               @relation("ApprovedPurchaseOrders", fields: [approvedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  rejectionReason  String?             @db.NVarChar(Max)
  assignedUserId   String?
  assignedUser     User?               @relation("AssignedPurchaseOrders", fields: [assignedUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  companyId        String?
  company          Company?            @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  items            PurchaseOrderItem[]
  deletedAt        DateTime?
  deletedById      String?
  deletedBy        User?               @relation("PurchaseOrderDeletedBy", fields: [deletedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@index([customerId])
  @@index([negotiationId])
  @@index([quotationId])
  @@index([dealId])
  @@index([status])
  @@index([assignedUserId])
  @@index([companyId])
}

model PurchaseOrderItem {
  id              String        @id @default(uuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  productId       String?
  product         Product?      @relation(fields: [productId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  description     String
  quantity        Float
  unitPrice       Float
  totalPrice      Float
  notes           String?

  @@index([purchaseOrderId])
}

model CRMDocument {
  id           String    @id @default(uuid())
  documentCode String    @unique
  name         String
  documentType String // Sample | Negotiation | PurchaseOrder | Quotation | RFQ | Customer | Product | Contract | Invoice | Other
  entityType   String // SampleRequest | Negotiation | PurchaseOrder | Quotation | RFQ | Customer | Product | Deal
  entityId     String
  fileUrl      String    @db.NVarChar(Max)
  fileSize     Int?
  mimeType     String?
  version      Int       @default(1)
  description  String?   @db.NVarChar(Max)
  tags         String?   @db.NVarChar(Max)
  uploadedById String
  uploadedBy   User      @relation("UploadedDocuments", fields: [uploadedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  companyId    String?
  company      Company?  @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  deletedAt    DateTime?
  deletedById  String?
  deletedBy    User?     @relation("DocumentDeletedBy", fields: [deletedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  Customer     Customer? @relation(fields: [customerId], references: [id])
  customerId   String?

  @@index([entityType, entityId])
  @@index([documentType])
  @@index([uploadedById])
  @@index([companyId])
}

model ApprovalRequest {
  id                String    @id @default(uuid())
  approvalCode      String    @unique
  approvalType      String // SampleApproval | NegotiationDiscount | PurchaseOrderApproval | DiscountApproval | Custom
  entityType        String // SampleRequest | Negotiation | PurchaseOrder | Deal
  entityId          String
  status            String    @default("Pending") // Pending | Approved | Rejected | Cancelled | Escalated
  requestedAmount   Float?
  requestedDiscount Float?
  justification     String?   @db.NVarChar(Max)
  remarks           String?   @db.NVarChar(Max)
  requestedById     String
  requestedBy       User      @relation("ApprovalRequestRequestedBy", fields: [requestedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  resolvedById      String?
  resolvedBy        User?     @relation("ApprovalRequestResolvedBy", fields: [resolvedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  resolvedAt        DateTime?
  dueDate           DateTime?
  priority          String    @default("Normal") // Low | Normal | High | Urgent
  companyId         String?
  company           Company?  @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([approvalType])
  @@index([entityType, entityId])
  @@index([status])
  @@index([requestedById])
  @@index([resolvedById])
  @@index([companyId])
}

model EmailTemplate {
  id        String    @id @default(uuid())
  name      String
  subject   String
  body      String    @db.NVarChar(Max)
  module    String    // "Quotation" | "PO" | "Negotiation" | "Sample" | "FollowUp"
  isActive  Boolean   @default(true)
  companyId String?
  company   Company?  @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([module])
  @@index([companyId])
}

model WhatsAppTemplate {
  id        String    @id @default(uuid())
  name      String
  message   String    @db.NVarChar(Max)
  module    String    // "Quotation" | "PO" | "Negotiation" | "Sample" | "FollowUp"
  isActive  Boolean   @default(true)
  companyId String?
  company   Company?  @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([module])
  @@index([companyId])
}

// --- Variant 4: Enterprise Manufacturing CRM ----------------------------------

model Competitor {
  id          String              @id @default(uuid())
  name        String
  website     String?
  description String?             @db.NVarChar(Max)
  strengths   String?             @db.NVarChar(Max)
  weaknesses  String?             @db.NVarChar(Max)
  isActive    Boolean             @default(true)
  companyId   String?
  company     Company?            @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  products          CompetitorProduct[]
  lostDealAnalyses  LostDealAnalysis[]

  @@index([companyId])
  @@index([isActive])
}

model CompetitorProduct {
  id           String     @id @default(uuid())
  competitorId String
  competitor   Competitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)
  name         String
  description  String?    @db.NVarChar(Max)
  priceRange   String?
  ourAdvantage String?    @db.NVarChar(Max)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([competitorId])
}

model LostDealAnalysis {
  id                  String      @id @default(uuid())
  dealId              String      @unique
  deal                Deal        @relation(fields: [dealId], references: [id], onDelete: Cascade)
  competitorId        String?
  competitor          Competitor? @relation(fields: [competitorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  lossReasonId        String?
  lossReason          LossReason? @relation(fields: [lossReasonId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  lostReason          String
  competitorWonPrice  Float?
  ourFinalPrice       Float?
  lessonsLearned      String?     @db.NVarChar(Max)
  recordedById        String
  recordedBy          User        @relation("RecordedLostDealAnalyses", fields: [recordedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  companyId           String?
  company             Company?    @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  @@index([dealId])
  @@index([competitorId])
  @@index([lossReasonId])
  @@index([companyId])
}

model LossReason {
  id        String   @id @default(uuid())
  name      String
  isActive  Boolean  @default(true)
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdAt DateTime @default(now())

  lostDealAnalyses LostDealAnalysis[]

  @@index([companyId])
  @@index([isActive])
}

model Territory {
  id             String     @id @default(uuid())
  name           String
  region         String
  states         String?    @db.NVarChar(Max) // comma-separated state/city names
  assignedUserId String?
  assignedUser   User?      @relation("AssignedTerritories", fields: [assignedUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  isActive       Boolean    @default(true)
  companyId      String?
  company        Company?   @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  accounts      TerritoryAccount[]
  salesTargets  SalesTarget[]

  @@index([companyId])
  @@index([isActive])
  @@index([assignedUserId])
}

model TerritoryAccount {
  id           String    @id @default(uuid())
  territoryId  String
  territory    Territory @relation(fields: [territoryId], references: [id], onDelete: Cascade)
  customerId   String
  customer     Customer  @relation(fields: [customerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  assignedAt   DateTime  @default(now())

  @@index([territoryId])
  @@index([customerId])
}

model SalesTarget {
  id              String     @id @default(uuid())
  targetType      String     // "Monthly" | "Quarterly" | "Yearly"
  period          String     // "2026-06" | "2026-Q2" | "2026"
  targetAmount    Float
  achievedAmount  Float      @default(0)
  assignedUserId  String?
  assignedUser    User?      @relation("AssignedSalesTargets", fields: [assignedUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  territoryId     String?
  territory       Territory? @relation(fields: [territoryId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  notes           String?    @db.NVarChar(Max)
  companyId       String?
  company         Company?   @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([targetType])
  @@index([period])
  @@index([assignedUserId])
  @@index([territoryId])
  @@index([companyId])
}

model KeyAccount {
  id                   String    @id @default(uuid())
  customerId           String
  customer             Customer  @relation(fields: [customerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  accountManagerId     String
  accountManager       User      @relation("ManagedKeyAccounts", fields: [accountManagerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  revenuePotential     Float?
  strategicImportance  String    @default("High") // "High" | "Medium" | "Critical"
  relationshipStatus   String?
  nextReviewDate       DateTime?
  notes                String?   @db.NVarChar(Max)
  companyId            String?
  company              Company?  @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([customerId])
  @@index([accountManagerId])
  @@index([strategicImportance])
  @@index([companyId])
}

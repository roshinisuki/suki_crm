  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  // Soft Delete
  deletedAt   DateTime?
  deletedById String?

  @@index([customerId])
  @@index([dealId])
  @@index([status])
  @@index([companyId])

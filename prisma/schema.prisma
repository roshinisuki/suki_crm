  @@index([status])
  @@index([assignedUserId])
  @@index([companyId])
  @@index([priority])
  @@index([customerDueDate])
  @@index([costingOwnerId])
  @@index([opportunityId])
  @@index([status, customerDueDate, assignedUserId])
}

model Quotation {
  id                       String                      @id @default(uuid())

model Task {
  id          String    @id @default(uuid())
  taskCode    String?
  title       String
  description String?   @db.NVarChar(Max)
  status      String    @default("Open")
  priority    String    @default("Medium")
  dueDate     DateTime?
  contactId   String?
  Contact     Contact?  @relation(fields: [contactId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  dealId      String?
  Deal        Deal?     @relation(fields: [dealId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  assignedTo  String
  User        User      @relation(fields: [assignedTo], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Phase 4: Completion & cancellation tracking
  completedAt        DateTime?
  cancellationReason String?   @db.NVarChar(Max)
  assignedBy         String?
  AssignedBy         User?     @relation("TaskAssignedBy", fields: [assignedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)

  // Phase 4: Comments
  comments TaskComment[]

  // Multi-Tenancy
  companyId String?

  // Soft Delete
  deletedAt   DateTime?
  deletedById String?

  @@index([assignedTo])
  @@index([contactId])
  @@index([dealId])
  @@index([status])
  @@index([companyId])
}

// â”€â”€â”€ Variant 2 Models â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

model ProductCategory {
  id          String    @id @default(uuid())
  name        String
  description String?
  isActive    Boolean   @default(true)
  companyId   String?
  company     Company?  @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([companyId])
  @@index([isActive])
}

model Product {
  id                 String                 @id @default(uuid())
  productCode        String                 @unique
  name               String
  categoryId         String?
  category           ProductCategory?       @relation(fields: [categoryId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  description        String?                @db.NVarChar(Max)
  unit               String?
  basePrice          Float?
  isActive           Boolean                @default(true)
  datasheetUrl       String?                @db.NVarChar(Max)
  brochureUrl        String?                @db.NVarChar(Max)
  // Variant 3 fields
  productType        String? // FinishedGood | RawMaterial | Component | SubAssembly | Consumable
  minOrderQuantity   Float?
  companyId          String?
  company            Company?               @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  specifications     ProductSpecification[]
  rfqs               RFQ[]
  rfqLineItems       RFQLineItem[]
  quotationItems     QuotationItem[]
  // Variant 3 relations
  samples            SampleRequest[]
  purchaseOrderItems PurchaseOrderItem[]
  deletedAt          DateTime?
  deletedById        String?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt

  @@index([companyId])
  @@index([categoryId])
  @@index([isActive])
}

model ProductSpecification {
  id           String   @id @default(uuid())
  productId    String
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  specKey      String
  specValue    String
  unit         String?
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([productId])
}

model RFQ {
  id                   String          @id @default(uuid())
  rfqCode              String          @unique
  customerId           String
  customer             Customer        @relation(fields: [customerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  contactId            String?
  contact              Contact?        @relation(fields: [contactId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  productId            String?
  product              Product?        @relation(fields: [productId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  status               String          @default("New")
  receivedDate         DateTime        @default(now())
  requirementDetails   String?         @db.NVarChar(Max)
  targetPrice          Float?
  deliveryDate         DateTime?
  quantity             Float?
  assignedUserId       String?
  assignedUser         User?           @relation("AssignedRFQs", fields: [assignedUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  notes                String?         @db.NVarChar(Max)
  // Variant 3 field
  expectedDeliveryDate DateTime?
  companyId            String?
  company              Company?        @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  deletedAt            DateTime?
  deletedById          String?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  quotations           Quotation[]
  // â”€â”€ Variant 2 gap-fill fields â”€â”€
  customerDueDate  DateTime?
  priority         String    @default("Normal")  // Urgent | Normal
  costingOwnerId   String?
  costingOwner     User?     @relation("CostingOwnerRFQs", fields: [costingOwnerId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  // Variant 2 relations
  lineItems        RFQLineItem[]
  costingSheets    RFQCostingSheet[]
  rfqStatusHistories RFQStatusHistory[]

  // Phase 7: linked opportunity
  opportunityId    String?
  opportunity      Deal?     @relation("OpportunityRFQs", fields: [opportunityId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  // Variant 3 relations
  samples              SampleRequest[]

  @@index([customerId])
  @@index([status])
  @@index([assignedUserId])
  @@index([companyId])
  @@index([priority])
  @@index([customerDueDate])
  @@index([costingOwnerId])
  @@index([opportunityId])
  @@index([status, customerDueDate, assignedUserId])
}

model Quotation {
  id                 String          @id @default(uuid())
  quotationCode      String          @unique
  rfqId              String?
  rfq                RFQ?            @relation(fields: [rfqId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  customerId         String
  customer           Customer        @relation(fields: [customerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  contactId          String?
  contact            Contact?        @relation(fields: [contactId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  dealId             String?
  deal               Deal?           @relation(fields: [dealId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  status             String          @default("Draft")
  validUntil         DateTime
  totalAmount        Float           @default(0)
  discountPercent    Float           @default(0)
  finalAmount        Float           @default(0)
  termsAndConditions String?         @db.NVarChar(Max)
  sentAt             DateTime?
  acceptedAt         DateTime?
  rejectedAt         DateTime?
  rejectionReason    String?         @db.NVarChar(Max)
  rejectionReasonId  String?
  createdById        String
  createdBy          User            @relation("CreatedQuotations", fields: [createdById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  companyId          String?
  company            Company?        @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  items              QuotationItem[]
  deletedAt          DateTime?
  deletedById        String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  // â”€â”€ Variant 2 gap-fill fields â”€â”€
  revisionNumber   Int       @default(1)
  pdfUrl           String?   @db.NVarChar(Max)
  subtotal         Float     @default(0)
  taxAmount        Float     @default(0)
  paymentTerms     String?   @db.NVarChar(Max)
  deliveryTerms    String?   @db.NVarChar(Max)
  freightTerms     String?
  leadTimeDays     Int?

  // Variant 2 relations
  assignedUser             User?                 @relation("AssignedQuotations", fields: [assignedUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  assignedUserId           String?
  quotationStatusHistories QuotationStatusHistory[]
  revisionSnapshots        QuotationRevisionSnapshot[]

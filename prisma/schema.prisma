model SystemConfig {
  key   String @id
  value String
}

model Lead {
  id             String   @id @default(uuid())
  leadCode       String   @unique
  name           String
  email          String?  @unique
  phone          String?
  city           String?
  status         String   @default("New")
  assignedUserId String?
  assignedUser   User?    @relation(fields: [assignedUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  leadSource     String   @default("Website")
  notes          String?  @db.NVarChar(Max)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // SLA Tracking Fields
  slaStatus           String    @default("Pending")
  slaResponseDeadline DateTime? // Set to createdAt + 15 min on ingestion
  firstRespondedAt    DateTime? // Set when status first moves away from New
  escalationLevel     Int       @default(0) // 0=None, 1=48h Manager Alert, 2=72h Auto-Reassign
  lastInteractionAt   DateTime  @default(now())

  // Qualification Fields (for SQL promotion)
  budgetAsked     String?
  timelineAsked   String?
  isDecisionMaker Boolean @default(false)
  isGenuine       Boolean @default(false)

  // Multi-Tenancy
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  // Soft Delete
  deletedAt   DateTime?
  deletedById String?

  communicationLogs CommunicationLog[]
  marketingVisits   MarketingVisit[]
  followUps         FollowUp[]
  callLogs          CallLog[]
  ownerHistory      LeadOwnerHistory[]

  // â”€â”€ Variant 2 gap-fill fields â”€â”€
  leadScore            Int       @default(0)   // 0â€“100 server-computed score
  companyName          String?                 // Separate from contact name
  designation          String?                 // Contact person's designation
  industryType         String?                 // Automotive | Pharma | Textile | FMCG | Others
  estimatedValue       Float?                  // Estimated deal value
  isDuplicateOf        String?                 // FK to another lead_id (self-ref, no enforced FK)
  convertedAccountId   String?                 // Set on conversion
  convertedOpportunityId String?               // Set on conversion
  lostReason           String?  @db.NVarChar(Max) // Free-text loss reason
  lostReasonRefId      String?                 // FK to LossReason.id

  // Variant 2 relations
  statusHistories LeadStatusHistory[]

  @@index([status])
  @@index([assignedUserId])
  @@index([slaStatus])
  @@index([escalationLevel])
  @@index([companyId])
  @@index([leadScore])
  @@index([isDuplicateOf])
  @@index([assignedUserId, status, createdAt])
}

model LeadOwnerHistory {
  id            String   @id @default(uuid())
  leadId        String
  lead          Lead     @relation(fields: [leadId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  fromUserId    String?
  fromUser      User?    @relation("OwnerHistoryFrom", fields: [fromUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  toUserId      String?
  toUser        User?    @relation("OwnerHistoryTo", fields: [toUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  changedById   String? // Null = SYSTEM auto-reassignment
  changedByUser User?    @relation("OwnerHistoryChangedBy", fields: [changedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  reason        String?  @db.NVarChar(Max)
  timestamp     DateTime @default(now())

  @@index([leadId])
  @@index([fromUserId])
  @@index([toUserId])
  @@index([changedById])
}

model CommunicationLog {
  id           String    @id @default(uuid())
  customerId   String?
  customer     Customer? @relation(fields: [customerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  leadId       String?
  lead         Lead?     @relation(fields: [leadId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  dealId       String?
  channel      String // "Call" | "Meeting" | "Note" | "Email" | "WhatsApp"
  direction    String // "Inbound" | "Outbound"
  status       String // e.g. "Completed", "Scheduled", "NoAnswer", "Delivered", "Failed"
  content      String    @db.NVarChar(Max)
  sentByUserId String?
  sentByUser   User?     @relation(fields: [sentByUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  sentAt       DateTime  @default(now())

  // Call/Meeting specific fields
  duration    Int? // minutes
  location    String? // for meetings
  mode        String? // "In-person" | "Virtual"
  agenda      String?   @db.NVarChar(Max)
  outcome     String?   @db.NVarChar(Max)
  meetingDate DateTime?

  // Follow-Up linking â€” each activity can be linked to a follow-up
  followUpId String?
  followUp   FollowUp? @relation(fields: [followUpId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  // Multi-Tenancy
  companyId String?

  // Soft Delete
  deletedAt   DateTime?
  deletedById String?

  // Phase 4: Meeting attendees
  attendees ActivityAttendee[]

  @@index([customerId])
  @@index([leadId])
  @@index([sentByUserId])
  @@index([channel])
  @@index([companyId])
  @@index([followUpId])
}

model Invoice {
  id            String    @id @default(uuid())
  invoiceNumber String    @unique

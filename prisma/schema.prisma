// â”€â”€â”€ LOCAL DEVELOPMENT SCHEMA (MySQL) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
// Used when DB_PROVIDER=mysql (or NODE_ENV=development)
// Connection string format: mysql://user:password@localhost:3306/database

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
  output     = "../node_modules/.prisma/client"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

// â”€â”€â”€ Enums â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

// â”€â”€â”€ Models â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

model User {
  id                    String    @id @default(uuid())
  email                 String    @unique
  name                  String
  passwordHash          String
  role                  String    @default("SalesExecutive")
  department            String? // Sales | Technical | Production | Quality | Management â€” Variant 3
  userType              String    @default("internal") // "internal" | "customer"
  phone                 String?
  profilePhoto          String?   @db.NVarChar(Max)
  isActive              Boolean   @default(true)
  isFirstLogin          Boolean   @default(true)
  otpCode               String?
  otpExpiry             DateTime?
  otpAttempts           Int       @default(0)
  resetToken            String?   @db.NVarChar(Max)
  resetTokenExpiry      DateTime?
  loginAttempts         Int       @default(0)
  lockedUntil           DateTime?
  lastLoginAt           DateTime?
  invitedBy             String?
  invitedAt             DateTime?
  rememberMe            Boolean   @default(false)
  lastActivityAt        DateTime?
  activationToken       String?   @db.NVarChar(Max)
  activationTokenExpiry DateTime?
  passwordSetAt         DateTime?
  theme                 String    @default("ember") // ember | ocean | forest | obsidian
  themeMode             String    @default("light") // light | dark
  preferredCurrency     String    @default("INR") // INR | USD | EUR â€” display currency preference
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  // Multi-Tenancy
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  // Soft Delete
  deletedAt   DateTime?
  deletedById String?

  marketingVisits     MarketingVisit[]        @relation("ExecutiveVisits")
  customerVisits      CustomerVisit[]
  hostedVisitors      Visitor[]
  auditLogs           AuditLog[]
  passwordResetTokens PasswordResetToken[]
  assignedFollowUps   FollowUp[]              @relation("AssignedFollowUps")
  completedFollowUps  FollowUp[]              @relation("CompletedFollowUps")
  assignedCustomers   Customer[]              @relation("AssignedCustomers")
  notifications       Notification[]
  notificationPrefs   NotificationPreference?
  assignedDeals       Deal[]
  callLogs            CallLog[]
  dealStageHistories  DealStageHistory[]

  // Enterprise relations
  leads              Lead[]
  onboardedCustomers Customer[]         @relation("OnboardedCustomers")
  approvedVisits     MarketingVisit[]   @relation("ApprovedVisits")
  assignedTickets    SupportTicket[]
  communicationLogs  CommunicationLog[]

  // Lead SLA Ownership History
  leadOwnerHistoryFrom      LeadOwnerHistory[] @relation("OwnerHistoryFrom")
  leadOwnerHistoryTo        LeadOwnerHistory[] @relation("OwnerHistoryTo")
  leadOwnerHistoryChangedBy LeadOwnerHistory[] @relation("OwnerHistoryChangedBy")

  approvedDiscounts  Deal[]            @relation("ApprovedDiscounts")
  requestedApprovals ApprovalHistory[] @relation("RequestedApprovals")
  resolvedApprovals  ApprovalHistory[] @relation("ResolvedApprovals")
  proposalVersions   ProposalVersion[]

  // Polymorphic Notes
  createdNotes Note[] @relation("CreatedNotes")

  // Contacts & Tasks
  Contact Contact[]
  Task    Task[]

  // Phase 4: Task assigned-by, task comments, activity attendees
  tasksAssignedBy   Task[]           @relation("TaskAssignedBy")
  taskComments      TaskComment[]
  activityAttendees ActivityAttendee[]

  // Variant 2 relations
  createdQuotations Quotation[]     @relation("CreatedQuotations")
  assignedQuotations Quotation[]   @relation("AssignedQuotations")
  forecastEntries   ForecastEntry[]
  rfqs              RFQ[]           @relation("AssignedRFQs")
  costingRFQs       RFQ[]           @relation("CostingOwnerRFQs")
  submittedCostingSheets RFQCostingSheet[] @relation("SubmittedCostingSheets")
  changedRFQStatuses    RFQStatusHistory[] @relation("ChangedRFQStatus")
  changedQuotationStatuses QuotationStatusHistory[] @relation("ChangedQuotationStatus")
  createdRevisionSnapshots QuotationRevisionSnapshot[] @relation("CreatedRevisionSnapshots")
  requestedQuotationApprovals QuotationApproval[] @relation("RequestedQuotationApprovals")
  quotationApprover     QuotationApproval[] @relation("QuotationApprover")

  // Variant 3 relations
  assignedSamples        SampleRequest[]       @relation("AssignedSamples")
  approvedSamples        SampleRequest[]       @relation("ApprovedSamples")
  rejectedSamples        SampleRequest[]       @relation("RejectedSamples")
  sampleDeletedBy        SampleRequest[]       @relation("SampleDeletedBy")
  assignedNegotiations   Negotiation[]         @relation("AssignedNegotiations")
  approvedNegotiations   Negotiation[]         @relation("ApprovedNegotiations")
  negotiationDeletedBy   Negotiation[]         @relation("NegotiationDeletedBy")
  negotiationRevisions   NegotiationRevision[] @relation("NegotiationRevisions")
  assignedPurchaseOrders PurchaseOrder[]       @relation("AssignedPurchaseOrders")
  approvedPurchaseOrders PurchaseOrder[]       @relation("ApprovedPurchaseOrders")
  purchaseOrderDeletedBy PurchaseOrder[]       @relation("PurchaseOrderDeletedBy")
  documents              CRMDocument[]         @relation("UploadedDocuments")
  documentDeletedBy      CRMDocument[]         @relation("DocumentDeletedBy")
  approvalRequests       ApprovalRequest[]     @relation("ApprovalRequestRequestedBy")
  approvalResolvedBy     ApprovalRequest[]     @relation("ApprovalRequestResolvedBy")

  // Variant 4 relations
  territoriesAssigned      Territory[]            @relation("AssignedTerritories")
  salesTargetsAssigned     SalesTarget[]          @relation("AssignedSalesTargets")
  keyAccountsManaged       KeyAccount[]           @relation("ManagedKeyAccounts")
  lostDealAnalysesRecorded LostDealAnalysis[]     @relation("RecordedLostDealAnalyses")

  // Phase 9 relations
  createdReportSchedules  ReportSchedule[]  @relation("CreatedReportSchedules")
  exportedReports         ReportExportLog[] @relation("ExportedReports")

  @@index([role])
  @@index([isActive])
  @@index([userType])
  @@index([companyId])
}

model Customer {
  id                String    @id @default(uuid())
  customerCode      String    @unique
  name              String
  email             String?   @unique
  phone             String?
  city              String?
  status            String    @default("Prospect")
  assignedUserId    String?
  assignedUser      User?     @relation("AssignedCustomers", fields: [assignedUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  onboardingStatus  String    @default("Pending")
  onboardedAt       DateTime?
  onboardedById     String?
  onboardedBy       User?     @relation("OnboardedCustomers", fields: [onboardedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  convertedFromLead String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Multi-Tenancy
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  // Soft Delete
  deletedAt   DateTime?
  deletedById String?

  subscriptions     Subscription[]
  marketingVisits   MarketingVisit[]
  customerVisits    CustomerVisit[]
  followUps         FollowUp[]
  deals             Deal[]
  callLogs          CallLog[]
  communicationLogs CommunicationLog[]
  contacts          Contact[]
  invoices          Invoice[]
  supportTickets    SupportTicket[]
  proposals         Proposal[]

  // Variant 2 relations
  rfqs       RFQ[]
  quotations Quotation[]

  // Variant 3 relations
  samples        SampleRequest[]
  negotiations   Negotiation[]
  purchaseOrders PurchaseOrder[]
  documents      CRMDocument[]

  // Variant 4 relations
  territoryAccounts TerritoryAccount[]
  keyAccounts        KeyAccount[]

  // Keep leadSource for history if converted
  leadSource String?

  // â”€â”€ Variant 2 gap-fill fields â”€â”€
  gstNumber        String?   // unique enforced at application layer (SQL Server cannot unique-index nullable)
  accountType      String    @default("Prospect") // Customer | Prospect | Distributor | OEM | Reseller
  industryType     String?   // Automotive | Pharma | Textile | FMCG | Infrastructure | Others
  billingAddress   String?   @db.NVarChar(Max)
  shippingAddress  String?   @db.NVarChar(Max)
  creditLimit      Float     @default(0)
  creditTermsDays  Int       @default(30)
  isKeyAccountV2   Boolean   @default(false)  // V2 flag for quick filtering
  lastActivityDate DateTime?

  // Variant 2 relations
  plantLocations       PlantLocation[]
  accountStatusHistories AccountStatusHistory[]
  creditHistories      AccountCreditHistory[]

  @@index([customerCode])
  @@index([status])
  @@index([assignedUserId])
  @@index([companyId])
  @@index([gstNumber])
  @@index([isKeyAccountV2])
}

model Subscription {
  id         String   @id @default(uuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])
  planName   String
  startDate  DateTime
  endDate    DateTime
  status     String   @default("Active")
  notes      String?  @db.NVarChar(Max)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Renewal Alert Sentinels (prevent duplicate notifications)
  renewalAlertSent30 Boolean @default(false)
  renewalAlertSent7  Boolean @default(false)

  // Multi-Tenancy
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  // Soft Delete
  deletedAt   DateTime?
  deletedById String?

  @@index([customerId])
  @@index([status])
  @@index([endDate])
  @@index([companyId])
}

model CustomerVisit {
  id               String    @id @default(uuid())
  customerId       String
  customer         Customer  @relation(fields: [customerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  hostedBy         String
  host             User      @relation(fields: [hostedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  purpose          String
  checkInTime      DateTime?
  checkOutTime     DateTime?
  meetingSummary   String?   @db.NVarChar(Max)
  outcome          String?
  customerDecision String?
  rejectionReason  String?   @db.NVarChar(Max)
  nextMeetingDate  DateTime?
  nextMeetingNotes String?   @db.NVarChar(Max)
  status           String    @default("PLANNED")
  priority         String    @default("Normal")
  meetingType      String?
  source           String?
  agenda           String?   @db.NVarChar(Max)
  department       String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Phase 6: Customer Visits fields
  plantLocationId       String?
  plantLocation         PlantLocation? @relation(fields: [plantLocationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  plannedDate           DateTime?
  plannedTime           String?
  gpsLat                Float?
  gpsLng                Float?
  gpsAnomaly            Boolean?
  visitSummary          String?   @db.NVarChar(Max)
  nextAction            String?
  linkedOpportunityId   String?
  linkedOpportunity     Deal?     @relation("VisitLinkedOpportunity", fields: [linkedOpportunityId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  visitAttendees        CustomerVisitAttendee[]

  // Multi-Tenancy
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  // Soft Delete
  deletedAt   DateTime?
  deletedById String?

  @@index([customerId])
  @@index([hostedBy])
  @@index([status])
  @@index([companyId])
  @@index([plantLocationId])
  @@index([linkedOpportunityId])
}

model CustomerVisitAttendee {
  id          String @id @default(uuid())
  visitId     String
  visit       CustomerVisit @relation(fields: [visitId], references: [id], onDelete: Cascade)
  contactId   String
  contact     Contact @relation(fields: [contactId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdAt   DateTime @default(now())

  @@index([visitId])
  @@index([contactId])
}

model MarketingVisit {
  id                 String    @id @default(uuid())
  executiveId        String
  executive          User      @relation("ExecutiveVisits", fields: [executiveId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  customerId         String?
  customer           Customer? @relation(fields: [customerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  leadId             String?
  lead               Lead?     @relation(fields: [leadId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  checkIn            DateTime?
  checkOut           DateTime?
  checkInLat         Float?
  checkInLng         Float?
  checkOutLat        Float?
  checkOutLng        Float?
  checkInPhoto       String?
  remarks            String?   @db.NVarChar(Max)
  nextMeetingDate    DateTime?
  createdAt          DateTime  @default(now())
  purpose            String?
  meetingDescription String?   @db.NVarChar(Max)
  outcome            String?
  customerDecision   String?
  rejectionReason    String?   @db.NVarChar(Max)
  nextMeetingNotes   String?   @db.NVarChar(Max)
  status             String    @default("REQUESTED") // REQUESTED, APPROVED, CHECKED_IN, COMPLETED, REJECTED
  approvedByUserId   String?
  approvedByUser     User?     @relation("ApprovedVisits", fields: [approvedByUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  approvedAt         DateTime?
  updatedAt          DateTime? @updatedAt

  // Multi-Tenancy
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  // Soft Delete
  deletedAt   DateTime?
  deletedById String?

  // Variant 2 relations
  attendees VisitAttendee[]

  @@index([executiveId])
  @@index([customerId])
  @@index([leadId])
  @@index([nextMeetingDate])
  @@index([status])
  @@index([companyId])
}

model Visitor {
  id           String    @id @default(uuid())
  visitorName  String
  company      String
  visitorEmail String?
  visitorPhone String
  purpose      String
  inTime       DateTime  @default(now())
  outTime      DateTime?
  hostUserId   String
  host         User      @relation(fields: [hostUserId], references: [id], onDelete: Cascade)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([hostUserId])
  @@index([inTime])
}

model AuditLog {
  id      String  @id @default(uuid())
  userId  String?
  user    User?   @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  module  String
  action  String
  details String? @db.NVarChar(Max)

  // Phase 2: State-Diff Audit Fields
  resourceId    String? // ID of the entity that changed (lead ID, customer ID, etc.)
  previousState String? @db.NVarChar(Max) // Snapshot of entity before the change
  newState      String? @db.NVarChar(Max) // Snapshot of entity after the change
  ipAddress     String? // Client IP address extracted from request headers
  userAgent     String? @db.NVarChar(Max) // Browser/client user agent string
  severity      String  @default("INFO") // INFO | WARN | HIGH | CRITICAL

  // Multi-Tenancy
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  timestamp DateTime @default(now())

  @@index([userId])
  @@index([module])
  @@index([timestamp])
  @@index([severity])
  @@index([resourceId])
  @@index([companyId])
  @@index([module, resourceId, timestamp])
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  otp       String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}

model FollowUp {
  id              String    @id @default(uuid())
  customerId      String?
  customer        Customer? @relation(fields: [customerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  leadId          String?
  lead            Lead?     @relation(fields: [leadId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  assignedUserId  String
  assignedUser    User      @relation("AssignedFollowUps", fields: [assignedUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  nextMeetingDate DateTime
  remarks         String?   @db.NVarChar(Max)
  status          String    @default("Pending")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // New fields for inbound/outbound workflow integration
  visitId     String?
  visitType   String? // INBOUND / OUTBOUND
  completedAt DateTime?
  notes       String?   @db.NVarChar(Max)

  // Advanced tracking fields
  dueDate         DateTime?
  reminderAt      DateTime?
  completedById   String?
  completedBy     User?     @relation("CompletedFollowUps", fields: [completedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  sourceType      String? // e.g. "LEAD_INGESTION", "VISIT_CHECKOUT", "MANUAL"
  sourceId        String?
  completionNotes String?   @db.NVarChar(Max)
  priority        String    @default("Medium") // Low, Medium, High
  escalationLevel Int       @default(0)
  autoCreated     Boolean   @default(false)
  type            String? // "Call" | "Meeting" | "Note" â€” links to activity type

  // Activities linked to this follow-up
  communicationLogs CommunicationLog[]

  // Phase 4: Chained follow-up link
  nextFollowupId String?
  nextFollowUp   FollowUp?  @relation("ChainedFollowUp", fields: [nextFollowupId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  prevFollowUps  FollowUp[] @relation("ChainedFollowUp")

  // Multi-Tenancy
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  // Soft Delete
  deletedAt   DateTime?
  deletedById String?

  @@index([customerId])
  @@index([leadId])
  @@index([assignedUserId])
  @@index([status])
  @@index([nextMeetingDate])
  @@index([completedById])
  @@index([companyId])
  @@index([type])
  @@index([assignedUserId, status, nextMeetingDate])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String   @db.NVarChar(Max)
  type      String // "follow_up", "visit", "system"
  link      String? // Optional URL for action linkage
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  @@index([userId, isRead, createdAt])
}

model NotificationPreference {
  id                  Int     @id @default(autoincrement())
  userId              String  @unique
  emailFollowUp       Boolean @default(true)
  emailVisitorCheckIn Boolean @default(false)
  inAppVisitUpdate    Boolean @default(true)
  notifyOnDealStatus  Boolean @default(true)
  notifyOnCallLog     Boolean @default(true)
  user                User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Deal {
  id                String             @id @default(uuid())
  dealName          String
  customerId        String
  customer          Customer           @relation(fields: [customerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  dealValue         Float
  expectedCloseDate DateTime
  assignedUserId    String?
  assignedUser      User?              @relation(fields: [assignedUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  notes             String?            @db.NVarChar(Max)
  status            String             @default("Active")
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  stageHistories    DealStageHistory[]

  // Discount & Locking fields
  discountPercent      Float   @default(0.0)
  discountStatus       String  @default("None") // "None" | "Pending" | "Approved" | "Rejected"
  isLocked             Boolean @default(false)
  discountNotes        String? @db.NVarChar(Max)
  discountApprovedById String?
  discountApprovedBy   User?   @relation("ApprovedDiscounts", fields: [discountApprovedById], references: [id], onDelete: NoAction, onUpdate: NoAction)

  lostReason        String?            @db.NVarChar(Max)
  approvalRemarks   String?            @db.NVarChar(Max)
  approvalHistory   ApprovalHistory[]
  proposals         Proposal[]
  opportunityDetail OpportunityDetail?

  // â”€â”€ Variant 2 gap-fill fields â”€â”€
  opportunityCode    String?  // OPP-YYYY-NNNNN, set on Deal creation via V2 flow
  probabilityPercent Int      @default(20)  // 0â€“100, updated per stage
  isOverdue          Boolean  @default(false)
  lostReasonRefId    String?  // FK to LossReason.id (named to avoid conflict with lostReason String field)
  lostReasonRef      LossReason? @relation("DealLossReason", fields: [lostReasonRefId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  // Variant 2 relations
  quotations         Quotation[]
  tasks              Task[]
  opportunityContacts OpportunityContact[]

  // Variant 3 relations
  negotiations   Negotiation[]
  purchaseOrders PurchaseOrder[]

  // Variant 4 relations
  lostDealAnalysis LostDealAnalysis?

  // Phase 6: linked visits
  linkedVisits     CustomerVisit[] @relation("VisitLinkedOpportunity")

  // Phase 7: linked RFQs
  rfqs             RFQ[]           @relation("OpportunityRFQs")

  // Multi-Tenancy
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  // Soft Delete
  deletedAt   DateTime?
  deletedById String?

  // Forecast & Renewal details
  forecastEntryDate DateTime?
  renewalDate       DateTime?

  @@index([customerId])
  @@index([assignedUserId])
  @@index([status])
  @@index([companyId])
  @@index([opportunityCode])
  @@index([isOverdue])
  @@index([status, assignedUserId, isOverdue, expectedCloseDate])
}

model OpportunityDetail {
  id     String @id @default(uuid())
  dealId String @unique
  deal   Deal   @relation(fields: [dealId], references: [id], onDelete: Cascade)

  // â”€â”€ Requirement Gathering (Discovery) Fields â”€â”€
  currentChallenges String? @db.NVarChar(Max)
  painPoints        String? @db.NVarChar(Max)
  painPointsList    String? @db.NVarChar(Max) // JSON string of checkboxes

  requiredFeatures String? @db.NVarChar(Max) // Legacy
  modulesRequired  String? @db.NVarChar(Max) // JSON string of checkboxes

  deploymentType       String? // Cloud SaaS, On-Premise
  integrationsRequired String? @db.NVarChar(Max) // JSON string of checkboxes

  userCountSales    Int?
  userCountManagers Int?
  userCountAdmins   Int?

  budgetRange        String?
  timeline           String?
  procurementProcess String?

  decisionMaker  String?
  influencer     String?
  budgetOwner    String?
  expectedGoLive DateTime?

  currentVendor        String?
  competitorsEvaluated String? @db.NVarChar(Max)

  // â”€â”€ Pre-Sales Review Fields â”€â”€
  proposedSolution     String? @db.NVarChar(Max)
  scopeClassification  String?
  estimatedDuration    String?
  developmentEffort    String?
  implementationEffort String?
  supportRequirements  String?

  // â”€â”€ Meeting Scheduled Fields â”€â”€
  meetingType         String?
  meetingMode         String?
  meetingDate         DateTime?
  meetingStatus       String?
  meetingDuration     Int?
  meetingParticipants String?   @db.NVarChar(Max)
  meetingLocation     String?   @db.NVarChar(Max)
  meetingAgenda       String?   @db.NVarChar(Max)
  meetingOutcome      String?   @db.NVarChar(Max)

  // â”€â”€ Demo Conducted Fields â”€â”€
  demoType            String?
  demoDate            DateTime?
  demoPresenter       String?
  demoDuration        Int?
  demoAttendees       String?   @db.NVarChar(Max)
  demoCustomerRating  String?
  demoInterestLevel   String?
  demoQuestionsRaised String?   @db.NVarChar(Max)

  // â”€â”€ Rejected Demo Fields â”€â”€
  demoRejectionReason  String?

// ─── LOCAL DEVELOPMENT SCHEMA (MySQL) ────────────────────────────────────────
// Used when DB_PROVIDER=mysql (or NODE_ENV=development)
// Connection string format: mysql://user:password@localhost:3306/database

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
  output     = "../node_modules/.prisma/client"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  Admin
  MarketingLead
  MarketingExecutive
  Customer
}

enum CustomerStatus {
  Active
  Inactive
  Prospect
  APPROVED
  REJECTED
  PENDING
}

enum SubscriptionStatus {
  Active
  Expired
  Cancelled
  Pending
}

enum FollowUpStatus {
  Pending
  Completed
  Overdue
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String
  passwordHash String
  role         Role     @default(MarketingExecutive)
  userType           String    @default("internal") // "internal" | "customer"
  phone              String?
  profilePhoto       String?   @db.Text
  isActive           Boolean   @default(true)
  isFirstLogin       Boolean   @default(true)
  otpCode            String?
  otpExpiry          DateTime?
  otpAttempts        Int       @default(0)
  resetToken         String?   @db.Text
  resetTokenExpiry   DateTime?
  loginAttempts      Int       @default(0)
  lockedUntil        DateTime?
  lastLoginAt        DateTime?
  invitedBy          String?
  invitedAt                DateTime?
  rememberMe               Boolean   @default(false)
  lastActivityAt           DateTime?
  activationToken          String?   @db.Text
  activationTokenExpiry    DateTime?
  passwordSetAt      DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  marketingVisits     MarketingVisit[]
  customerVisits      CustomerVisit[]
  hostedVisitors      Visitor[]
  auditLogs           AuditLog[]
  passwordResetTokens PasswordResetToken[]
  assignedFollowUps   FollowUp[]
  assignedCustomers   Customer[] @relation("AssignedCustomers")
  notifications       Notification[]
  notificationPrefs   NotificationPreference?

  @@index([role])
  @@index([isActive])
  @@index([userType])
}

model Customer {
  id           String         @id @default(uuid())
  customerCode String         @unique
  name         String
  email        String?        @unique
  phone        String?
  city           String?
  status         CustomerStatus @default(Active)
  assignedUserId String?
  assignedUser   User?          @relation("AssignedCustomers", fields: [assignedUserId], references: [id])
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  subscriptions Subscription[]
  marketingVisits MarketingVisit[]
  customerVisits  CustomerVisit[]
  followUps     FollowUp[]

  @@index([customerCode])
  @@index([status])
  @@index([assignedUserId])
}

model Subscription {
  id         String             @id @default(uuid())
  customerId String
  customer   Customer           @relation(fields: [customerId], references: [id])
  planName   String
  startDate  DateTime
  endDate    DateTime
  status     SubscriptionStatus @default(Active)
  notes      String?            @db.Text
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  @@index([customerId])
  @@index([status])
  @@index([endDate])
}

model CustomerVisit {
  id                 String    @id @default(uuid())
  customerId         String
  customer           Customer  @relation(fields: [customerId], references: [id])
  hostedBy           String
  host               User      @relation(fields: [hostedBy], references: [id])
  purpose            String    // Sales Meeting / Subscription Discussion / Support / Demo / Other
  checkInTime        DateTime  @default(now())
  checkOutTime       DateTime?
  meetingSummary     String?   @db.Text
  outcome            String?   // Interested / Not Interested / Follow-up Required / Pending Decision / Converted
  customerDecision   String?   // APPROVED / REJECTED / PENDING
  rejectionReason    String?   @db.Text
  nextMeetingDate    DateTime?
  nextMeetingNotes   String?   @db.Text
  status             String    @default("CHECKED_IN") // CHECKED_IN / CHECKED_OUT
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([customerId])
  @@index([hostedBy])
  @@index([status])
}

model MarketingVisit {
  id                 String    @id @default(uuid())
  executiveId        String
  executive          User      @relation(fields: [executiveId], references: [id])
  customerId         String
  customer           Customer  @relation(fields: [customerId], references: [id])
  checkIn            DateTime  @default(now())
  checkOut           DateTime?
  checkInLat         Float?
  checkInLng         Float?
  checkOutLat        Float?
  checkOutLng        Float?
  checkInPhoto       String?
  remarks            String?   @db.Text
  nextMeetingDate    DateTime?
  createdAt          DateTime  @default(now())

  // New fields for high fidelity outbound field visits workflow
  purpose            String?   // Sales Pitch / Follow-up Meeting / Subscription Renewal / Demo / Support Visit / Other
  meetingDescription String?   @db.Text
  outcome            String?   // Interested / Not Interested / Follow-up Required / Pending Decision / Converted
  customerDecision   String?   // APPROVED / REJECTED / PENDING
  rejectionReason    String?   @db.Text
  nextMeetingNotes   String?   @db.Text
  status             String    @default("CHECKED_IN") // CHECKED_IN / CHECKED_OUT
  updatedAt          DateTime? @updatedAt

  @@index([executiveId])
  @@index([customerId])
  @@index([nextMeetingDate])
  @@index([checkIn])
  @@index([status])
}

model Visitor {
  id           String    @id @default(uuid())
  visitorName  String
  company      String
  visitorEmail String?
  visitorPhone String
  purpose      String
  inTime       DateTime  @default(now())
  outTime      DateTime?
  hostUserId   String
  host         User      @relation(fields: [hostUserId], references: [id])
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([hostUserId])
  @@index([inTime])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  module    String
  action    String
  details   String?  @db.Text
  timestamp DateTime @default(now())

  @@index([userId])
  @@index([module])
  @@index([timestamp])
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  otp       String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}

model FollowUp {
  id              String         @id @default(uuid())
  customerId      String
  customer        Customer       @relation(fields: [customerId], references: [id])
  assignedUserId  String
  assignedUser    User           @relation(fields: [assignedUserId], references: [id])
  nextMeetingDate DateTime
  remarks         String?        @db.Text
  status          FollowUpStatus @default(Pending)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  // New fields for inbound/outbound workflow integration
  visitId         String?
  visitType       String?        // INBOUND / OUTBOUND
  completedAt     DateTime?
  notes           String?        @db.Text

  @@index([customerId])
  @@index([assignedUserId])
  @@index([status])
  @@index([nextMeetingDate])
}

model Notification {
  id         String   @id @default(uuid())
  userId     String
  title      String
  message    String   @db.Text
  type       String   // "follow_up", "visit", "system"
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

model NotificationPreference {
  id                  Int     @id @default(autoincrement())
  userId              String  @unique
  emailFollowUp       Boolean @default(true)
  emailVisitorCheckIn Boolean @default(false)
  inAppVisitUpdate    Boolean @default(true)
  user                User    @relation(fields: [userId], references: [id])
}

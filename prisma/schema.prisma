  createdAt       DateTime  @default(now())
  resolvedAt      DateTime?

  // Soft Delete
  deletedAt   DateTime?
  deletedById String?

  @@index([dealId])
  @@index([entityType, entityId])
  @@index([approvalType])
  @@index([status])
  @@index([companyId])
}

model Company {

model LeadSource {
  id        String   @id @default(uuid())
  name      String   @unique
  isActive  Boolean  @default(true)
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdAt DateTime @default(now())
}

model Note {
  id          String    @id @default(uuid())
  content     String    @db.NVarChar(Max)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  createdById String
  createdBy   User      @relation("CreatedNotes", fields: [createdById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  entityType  String // "LEAD" | "CONTACT" | "VISIT" | "DEAL" | "PROPOSAL" | "NEGOTIATION"
  entityId    String // Target record UUID
  deletedAt   DateTime?
  deletedById String?
  companyId   String?
  company     Company?  @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([entityType, entityId])
  @@index([createdById])
  @@index([companyId])
}

model Contact {
  id          String    @id @default(uuid())
  contactCode String?
  name        String
  email       String?
  phone       String?
  company     String?
  title       String?
  designation String?
  dateOfBirth DateTime?
  preferredChannel   String? // Phone | Email | WhatsApp | SMS
  bestTimeToCall     String? // Morning | Afternoon | Evening
  languagePreference String? // English | Hindi | Tamil | Telugu | etc.
  status      String    @default("Active")
  contactType String    @default("Technical") // Technical | Purchase | Finance | Management
  isPrimary   Boolean   @default(false)
  notes       String?   @db.NVarChar(Max)
  customerId  String?
  customer    Customer? @relation(fields: [customerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  ownerId     String
  User        User      @relation(fields: [ownerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Multi-Tenancy
  companyId String?

  // Soft Delete
  deletedAt   DateTime?
  deletedById String?

  Task Task[]

  // Phase 4: Activity attendees
  activityAttendees ActivityAttendee[]

  // Variant 2 relations
  rfqs       RFQ[]
  quotations    Quotation[]
  opportunityContacts OpportunityContact[]

  // Variant 3 relations
  negotiations   Negotiation[]
  purchaseOrders PurchaseOrder[]
  samples        SampleRequest[]

  // Phase 6: visit attendees
  visitAttendees   CustomerVisitAttendee[]

  @@index([ownerId])
  @@index([status])
  @@index([customerId])
  @@index([contactType])
  @@index([companyId])

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  Admin
  MarketingLead
  MarketingExecutive
  Customer
}

enum CustomerStatus {
  Active
  Inactive
  Prospect
}

enum SubscriptionStatus {
  Active
  Expired
  Cancelled
  Pending
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String
  passwordHash String
  role         Role     @default(MarketingExecutive)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  marketingVisits     MarketingVisit[]
  hostedVisitors      Visitor[]
  auditLogs           AuditLog[]
  passwordResetTokens PasswordResetToken[]

  @@index([role])
  @@index([isActive])
}

model Customer {
  id           String         @id @default(uuid())
  customerCode String         @unique  // Manually entered, not auto-generated
  name         String
  email        String?
  phone        String?
  city         String?
  status       CustomerStatus @default(Active)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  subscriptions Subscription[]
  visits        MarketingVisit[]

  @@index([customerCode])
  @@index([status])
}

model Subscription {
  id         String             @id @default(uuid())
  customerId String
  customer   Customer           @relation(fields: [customerId], references: [id])
  planName   String
  startDate  DateTime
  endDate    DateTime
  status     SubscriptionStatus @default(Active)
  notes      String?            @db.Text
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  @@index([customerId])
  @@index([status])
  @@index([endDate])
}

model MarketingVisit {
  id              String    @id @default(uuid())
  executiveId     String
  executive       User      @relation(fields: [executiveId], references: [id])
  customerId      String
  customer        Customer  @relation(fields: [customerId], references: [id])
  checkIn         DateTime  @default(now())
  checkOut        DateTime?
  remarks         String?   @db.Text
  nextMeetingDate DateTime?
  createdAt       DateTime  @default(now())

  @@index([executiveId])
  @@index([customerId])
  @@index([nextMeetingDate])
  @@index([checkIn])
}

model Visitor {
  id           String    @id @default(uuid())
  visitorName  String
  visitorEmail String?
  visitorPhone String
  purpose      String
  inTime       DateTime  @default(now())
  outTime      DateTime?
  hostUserId   String
  host         User      @relation(fields: [hostUserId], references: [id])
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([hostUserId])
  @@index([inTime])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  module    String
  action    String
  details   String?  @db.Text
  timestamp DateTime @default(now())

  @@index([userId])
  @@index([module])
  @@index([timestamp])
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  otp       String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}
